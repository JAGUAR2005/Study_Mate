# Server-side only. Never expose these values to the browser.
AI_PROVIDER=openai

# OpenAI is the primary provider for this project.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
RAG_EMBEDDING_MODEL=text-embedding-3-small

# Optional Gemini alternative for a lower-cost/free-tier path.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# Supabase: public values are used only by the signed-in browser client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional Headroom proxy or Cloud configuration for AI context compression.
# Headroom is an open-source context optimization layer:
# https://github.com/ai-headroom/headroom
HEADROOM_BASE_URL=
HEADROOM_API_KEY=
# Optional maximum compressed prompt size in tokens.
HEADROOM_TOKEN_BUDGET=
